# =============================================================================
# config.env — Configuration for official TAK Server (GoC)
# =============================================================================
# Copy this file to config.env and fill in your values:
#   cp config.env.example config.env
#
# Then run ./build.sh to generate cloud-init.yaml.
# =============================================================================

# --- Server ---
TAK_HOSTNAME="tak-server"
TAK_TIMEZONE="Europe/Stockholm"
TAK_LOCALE="sv_SE.UTF-8"

# --- SSH ---
# Your public SSH key (ed25519 recommended)
SSH_PUBLIC_KEY="ssh-ed25519 AAAA... user@host"

# --- Domain ---
TAK_DOMAIN="tak.example.com"

# --- Certbot ---
CERTBOT_EMAIL="admin@example.com"

# --- Hetzner deployment ---
HETZNER_SERVER_TYPE="cx33"
HETZNER_IMAGE="ubuntu-22.04"
HETZNER_LOCATION="fsn1"
# Pre-allocated primary IP with DNS already pointing to it
# Create one with: hcloud primary-ip create --name tak-ip --type ipv4 --datacenter fsn1-dc14
# Then set your DNS A record for TAK_DOMAIN → this IP
HETZNER_PRIMARY_IP="tak-ip"

# --- TAK Server installer ---
# Download the TAK Server Docker release from https://tak.gov/products/tak-server
# Place the .zip file in this directory and set the filename below.
# Example: takserver-docker-5.3-RELEASE-1.zip
TAK_ZIP_FILENAME="takserver-docker-5.3-RELEASE-1.zip"

# --- TAK Server certificate details ---
# Organization fields used when generating the Root CA and client certs.
TAK_STATE="State"
TAK_CITY="City"
TAK_ORGANIZATION="MyOrg"
TAK_ORGANIZATIONAL_UNIT="TAK"

# Certificate passwords — change before deploying.
TAK_CA_PASS="atakatak"
TAK_ADMIN_PASS="atakatak"

# --- CloudTAK (optional) ---
# Web-based TAK client: https://github.com/dfpc-coe/CloudTAK
# Set both domains and ensure DNS A records point to this server.
# Leave empty to skip CloudTAK installation.
CLOUDTAK_DOMAIN="cloudtak.example.com"
TILES_DOMAIN="tiles.cloudtak.example.com"
