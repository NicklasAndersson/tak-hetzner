# =============================================================================
# config.env — Configuration variables for TAK Server
# =============================================================================
# Copy this file to config.env and fill in your values:
#   cp config.env.example config.env
#
# Then run ./build.sh to generate cloud-init.yaml.
# =============================================================================

# --- Server ---
TAK_HOSTNAME="tak-server"
TAK_TIMEZONE="Europe/Stockholm"
TAK_LOCALE="sv_SE.UTF-8"

# --- SSH ---
# Your public SSH key (ed25519 recommended)
SSH_PUBLIC_KEY="ssh-ed25519 AAAA... user@host"

# --- Domains ---
OTS_DOMAIN="tak.example.com"
CLOUDTAK_DOMAIN="cloudtak.example.com"
TILES_DOMAIN="tiles.cloudtak.example.com"

# --- Hetzner deployment ---
HETZNER_SERVER_TYPE="cx31"
HETZNER_IMAGE="ubuntu-24.04"
HETZNER_LOCATION="fsn1"
HETZNER_PRIMARY_IP="tak-server-ip"

# --- ADS-B position (WGS84) ---
ADSB_LAT="59.3293"
ADSB_LON="18.0686"
ADSB_RADIUS="249"
